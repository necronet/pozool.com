---
import Analytics from "@vercel/analytics/astro";
import { Image } from "astro:assets";
import pozoolLogo from "../../assets/pozool-logo.png";

type BlogLanguage = "en" | "es";
type BlogFrontmatter = {
    title: string;
    date: string;
    lang: BlogLanguage;
    excerpt: string;
    draft?: boolean;
};
type BlogModule = {
    frontmatter: BlogFrontmatter;
    Content: unknown;
};

export async function getStaticPaths() {
    const postModules = import.meta.glob<BlogModule>(
        "../../content/blog/*.md",
        { eager: true },
    );

    return Object.entries(postModules)
        .map(([path, post]) => ({
            slug: path.split("/").pop()?.replace(/\.md$/, "") ?? "",
            post,
        }))
        .filter(({ slug, post }) => slug && !post.frontmatter.draft)
        .map(({ slug, post }) => ({
            params: { slug },
            props: { post },
        }));
}

const { post } = Astro.props;
const { Content } = post;
const postTitle = post.frontmatter.title;
const postDescription = post.frontmatter.excerpt;
const languageLabels = {
    en: "English",
    es: "Español",
};
const postDate = new Intl.DateTimeFormat(post.frontmatter.lang, {
    dateStyle: "long",
    timeZone: "UTC",
}).format(new Date(post.frontmatter.date));
---

<html lang={post.frontmatter.lang}>
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="author" content="Pozool" />
        <meta name="description" content={postDescription} />
        <meta property="og:title" content={`${postTitle} | Pozool`} />
        <meta property="og:description" content={postDescription} />
        <meta property="og:type" content="article" />
        <meta name="twitter:card" content="summary" />
        <title>{postTitle} | Pozool</title>
        <link
            rel="alternate"
            type="application/rss+xml"
            title="Pozool Blog RSS Feed"
            href="/blog/rss.xml"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --radius: 0.75rem;
                --background: oklch(99% 0.005 70);
                --foreground: #000;
                --card: oklch(100% 0 0);
                --primary: oklch(70% 0.19 45);
                --muted-foreground: #000;
                --border: oklch(92% 0.012 70);
                --ink-soft: #000;
                --gradient-primary: linear-gradient(
                    135deg,
                    oklch(70% 0.19 45),
                    oklch(78% 0.17 55)
                );
                --gradient-warm: linear-gradient(
                    180deg,
                    oklch(99% 0.01 80),
                    oklch(96% 0.03 60)
                );
                --shadow-elegant: 0 20px 50px -20px
                    oklab(70% 0.13435 0.13435 / 0.3);
                --shadow-soft: 0 10px 30px -15px rgb(0 0 0 / 0.12);
                --transition-smooth: 0.35s cubic-bezier(0.22, 1, 0.36, 1);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                font-family: "Inter", system-ui, sans-serif;
                background: var(--background);
                color: var(--foreground);
                -webkit-font-smoothing: antialiased;
                text-rendering: optimizeLegibility;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            img {
                display: block;
                max-width: 100%;
            }

            .site-shell {
                min-height: 100vh;
                background: var(--gradient-warm);
            }

            .container {
                width: min(100%, 72rem);
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            .header {
                position: sticky;
                top: 0;
                z-index: 50;
                background: rgb(252 251 248 / 0.8);
                backdrop-filter: blur(14px);
                border-bottom: 1px solid rgb(230 225 214 / 0.7);
            }

            .header-inner {
                min-height: 4rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
            }

            .brand {
                display: inline-flex;
                align-items: center;
                gap: 0.625rem;
                font-size: 1.125rem;
                font-weight: 700;
                letter-spacing: -0.025em;
            }

            .brand img {
                width: 2.25rem;
                height: 2.25rem;
                border-radius: calc(var(--radius) - 0.125rem);
                box-shadow: var(--shadow-soft);
            }

            .nav {
                display: flex;
                align-items: center;
                gap: 0.25rem;
            }

            .nav a {
                padding: 0.625rem 0.75rem;
                border-radius: calc(var(--radius) - 0.125rem);
                font-size: 0.875rem;
                font-weight: 500;
                color: var(--ink-soft);
                transition:
                    color var(--transition-smooth),
                    background var(--transition-smooth);
            }

            .nav a:hover,
            .nav a[aria-current="page"] {
                color: var(--foreground);
                background: rgb(255 255 255 / 0.55);
            }

            main {
                padding: clamp(4rem, 9vw, 7rem) 0;
            }

            .back-link {
                display: inline-flex;
                align-items: center;
                margin-bottom: 2rem;
                color: var(--ink-soft);
                font-size: 0.9rem;
                font-weight: 600;
            }

            .back-link:hover {
                color: var(--foreground);
            }

            article {
                padding: clamp(1.5rem, 4vw, 3rem);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                background: rgb(255 255 255 / 0.78);
                box-shadow: var(--shadow-elegant);
            }

            h1,
            p {
                margin: 0;
            }

            .post-meta {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                align-items: center;
                color: var(--primary);
                font-size: 0.875rem;
                font-weight: 700;
            }

            .post-language {
                display: inline-flex;
                align-items: center;
                min-height: 1.5rem;
                padding: 0 0.5rem;
                border: 1px solid rgb(221 130 71 / 0.28);
                border-radius: 999px;
                background: rgb(255 255 255 / 0.62);
                color: var(--ink-soft);
                font-size: 0.72rem;
                font-weight: 700;
                text-transform: uppercase;
            }

            h1 {
                margin-top: 0.75rem;
                font-size: clamp(2.5rem, 7vw, 4.25rem);
                line-height: 0.98;
                letter-spacing: -0.04em;
                text-wrap: balance;
            }

            .content {
                margin-top: clamp(2rem, 5vw, 3rem);
                color: var(--muted-foreground);
                font-size: 1.125rem;
                line-height: 1.85;
            }

            .content :global(p) {
                margin: 0;
            }

            .content :global(p + p),
            .content :global(p + h2),
            .content :global(ul + p),
            .content :global(ol + p) {
                margin-top: 1.35rem;
            }

            .content :global(p:first-child) {
                color: var(--ink-soft);
                font-size: 1.25rem;
                line-height: 1.75;
            }

            .content :global(h2) {
                margin: 2rem 0;
                color: var(--foreground);
                font-size: 1.65rem;
                line-height: 1.2;
                letter-spacing: -0.02em;
            }

            .content :global(ul),
            .content :global(ol) {
                margin: 1rem 0 0;
                padding-left: 1.4rem;
            }

            .content :global(li + li) {
                margin-top: 0.5rem;
            }

            @media (max-width: 36rem) {
                .container {
                    padding: 0 1rem;
                }

                .brand {
                    font-size: 1rem;
                }

                .nav a {
                    padding: 0.55rem 0.625rem;
                }

                main {
                    padding-top: 3rem;
                }
            }
        </style>
    </head>
    <body>
        <div class="site-shell">
            <header class="header">
                <div class="container header-inner">
                    <a class="brand" href="/" aria-label="Pozool home">
                        <Image
                            src={pozoolLogo}
                            alt=""
                            width={64}
                            height={64}
                            format="webp"
                        />
                        <span>Pozool</span>
                    </a>

                    <nav class="nav" aria-label="Blog navigation">
                        <a href="/blog" aria-current="page">Blog</a>
                        <a href="/">Home</a>
                    </nav>
                </div>
            </header>

            <main>
                <div class="container article-container">
                    <a class="back-link" href="/blog">Back to blog</a>

                    <article>
                        <h1>{postTitle}</h1>

                        <div class="content">
                            <Content />
                        </div>
                    </article>
                </div>
            </main>
        </div>
        <Analytics />
    </body>
</html>
