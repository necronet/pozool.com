---
import Analytics from "@vercel/analytics/astro";
import { Image } from "astro:assets";
import pozoolLogo from "../../assets/pozool-logo.png";

type BlogLanguage = "en" | "es";
type BlogFrontmatter = {
    title: string;
    date: string;
    lang: BlogLanguage;
    excerpt: string;
    draft?: boolean;
};
type BlogPost = {
    slug: string;
    frontmatter: BlogFrontmatter;
};

const languageLabels = {
    en: "English",
    es: "Español",
};

const formatPostDate = (date: string, lang: keyof typeof languageLabels) =>
    new Intl.DateTimeFormat(lang, {
        dateStyle: "long",
        timeZone: "UTC",
    }).format(new Date(date));

const postModules = import.meta.glob<{ frontmatter: BlogFrontmatter }>(
    "../../content/blog/*.md",
    {
        eager: true,
    },
);

const posts: BlogPost[] = Object.entries(postModules)
    .map(([path, post]) => ({
        slug: path.split("/").pop()?.replace(/\.md$/, "") ?? "",
        frontmatter: post.frontmatter,
    }))
    .filter((post) => post.slug && !post.frontmatter.draft)
    .sort(
        (a, b) =>
            new Date(b.frontmatter.date).getTime() -
            new Date(a.frontmatter.date).getTime(),
    );
---

<html lang="en" data-lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="author" content="Pozool" />
        <meta
            name="description"
            content="Updates and notes from the Pozool team."
        />
        <meta property="og:title" content="Pozool Blog" />
        <meta
            property="og:description"
            content="Updates and notes from the Pozool team."
        />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary" />
        <title>Pozool Blog</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --radius: 0.75rem;
                --background: oklch(99% 0.005 70);
                --foreground: #000;
                --card: oklch(100% 0 0);
                --primary: oklch(70% 0.19 45);
                --primary-glow: oklch(78% 0.17 55);
                --secondary: oklch(96% 0.012 70);
                --muted-foreground: #000;
                --border: oklch(92% 0.012 70);
                --ink-soft: #000;
                --surface-warm: oklch(97% 0.02 70);
                --gradient-primary: linear-gradient(
                    135deg,
                    oklch(70% 0.19 45),
                    oklch(78% 0.17 55)
                );
                --gradient-warm: linear-gradient(
                    180deg,
                    oklch(99% 0.01 80),
                    oklch(96% 0.03 60)
                );
                --shadow-elegant: 0 20px 50px -20px
                    oklab(70% 0.13435 0.13435 / 0.3);
                --shadow-soft: 0 10px 30px -15px rgb(0 0 0 / 0.12);
                --transition-smooth: 0.35s cubic-bezier(0.22, 1, 0.36, 1);
            }

            * {
                box-sizing: border-box;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                margin: 0;
                font-family: "Inter", system-ui, sans-serif;
                background: var(--background);
                color: var(--foreground);
                -webkit-font-smoothing: antialiased;
                text-rendering: optimizeLegibility;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            img {
                display: block;
                max-width: 100%;
            }

            .site-shell {
                min-height: 100vh;
                background: var(--gradient-warm);
            }

            .container {
                width: min(100%, 72rem);
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            .header {
                position: sticky;
                top: 0;
                z-index: 50;
                background: rgb(252 251 248 / 0.8);
                backdrop-filter: blur(14px);
                border-bottom: 1px solid rgb(230 225 214 / 0.7);
            }

            .header-inner {
                min-height: 4rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
            }

            .brand {
                display: inline-flex;
                align-items: center;
                gap: 0.625rem;
                font-size: 1.125rem;
                font-weight: 700;
                letter-spacing: -0.025em;
            }

            .brand img {
                width: 2.25rem;
                height: 2.25rem;
                border-radius: calc(var(--radius) - 0.125rem);
                box-shadow: var(--shadow-soft);
            }

            .nav {
                display: flex;
                align-items: center;
                gap: 0.25rem;
            }

            .nav a {
                padding: 0.625rem 0.75rem;
                border-radius: calc(var(--radius) - 0.125rem);
                font-size: 0.875rem;
                font-weight: 500;
                color: var(--ink-soft);
                transition:
                    color var(--transition-smooth),
                    background var(--transition-smooth);
            }

            .nav a:hover,
            .nav a[aria-current="page"] {
                color: var(--foreground);
                background: rgb(255 255 255 / 0.55);
            }

            .header-actions {
                display: inline-flex;
                align-items: center;
                gap: 0.75rem;
            }

            .language-toggle {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 2.75rem;
                height: 2.5rem;
                padding: 0 0.8rem;
                border: 1px solid var(--border);
                border-radius: 999px;
                background: rgb(255 255 255 / 0.75);
                color: var(--foreground);
                font: inherit;
                font-size: 0.8rem;
                font-weight: 700;
                cursor: pointer;
                transition:
                    transform var(--transition-smooth),
                    background var(--transition-smooth);
            }

            .language-toggle:hover {
                transform: translateY(-1px);
                background: var(--card);
            }

            .i18n-es {
                display: none;
            }

            html[data-lang="es"] .i18n-en {
                display: none;
            }

            html[data-lang="es"] .i18n-es {
                display: inline;
            }

            html[data-lang="es"] p.i18n-es {
                display: block;
            }

            main {
                padding: clamp(4rem, 9vw, 7rem) 0;
            }

            .blog-heading {
                max-width: 44rem;
            }

            .eyebrow {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.4rem 0.8rem;
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 999px;
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--ink-soft);
            }

            .eyebrow-dot {
                width: 0.375rem;
                height: 0.375rem;
                border-radius: 999px;
                background: var(--primary);
            }

            h1,
            h2,
            p {
                margin: 0;
            }

            h1 {
                margin-top: 1.25rem;
                font-size: clamp(3rem, 8vw, 4.5rem);
                line-height: 0.98;
                letter-spacing: -0.04em;
                text-wrap: balance;
            }

            .gradient-text {
                background: var(--gradient-primary);
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }

            .lead {
                margin-top: 1.25rem;
                max-width: 36rem;
                font-size: 1.125rem;
                line-height: 1.7;
                color: var(--ink-soft);
            }

            .posts {
                margin-top: clamp(2.5rem, 6vw, 4rem);
                display: grid;
                gap: 1.5rem;
            }

            .post-card {
                display: block;
                padding: clamp(1.5rem, 4vw, 2.5rem);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                background: rgb(255 255 255 / 0.78);
                box-shadow: var(--shadow-elegant);
                transition:
                    transform var(--transition-smooth),
                    border-color var(--transition-smooth),
                    background var(--transition-smooth);
            }

            .post-card:hover {
                transform: translateY(-2px);
                border-color: rgb(221 130 71 / 0.42);
                background: rgb(255 255 255 / 0.9);
            }

            .post-card[hidden] {
                display: none;
            }

            .post-meta {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                align-items: center;
                color: var(--primary);
                font-size: 0.875rem;
                font-weight: 700;
            }

            .post-language {
                display: inline-flex;
                align-items: center;
                min-height: 1.5rem;
                padding: 0 0.5rem;
                border: 1px solid rgb(221 130 71 / 0.28);
                border-radius: 999px;
                background: rgb(255 255 255 / 0.62);
                color: var(--ink-soft);
                font-size: 0.72rem;
                font-weight: 700;
                text-transform: uppercase;
            }

            .post-card h2 {
                margin-top: 0.75rem;
                max-width: 46rem;
                font-size: clamp(2rem, 5vw, 3.25rem);
                line-height: 1;
                letter-spacing: -0.035em;
                text-wrap: balance;
            }

            .post-content {
                margin-top: 1.25rem;
                max-width: 40rem;
                color: var(--muted-foreground);
                font-size: 1.125rem;
                line-height: 1.8;
            }

            .empty-state {
                color: var(--muted-foreground);
                font-size: 1.05rem;
                line-height: 1.7;
            }

            .empty-state[hidden] {
                display: none;
            }

            @media (max-width: 36rem) {
                .container {
                    padding: 0 1rem;
                }

                .brand {
                    font-size: 1rem;
                }

                .nav a {
                    padding: 0.55rem 0.625rem;
                }

                main {
                    padding-top: 3rem;
                }
            }
        </style>
    </head>
    <body>
        <div class="site-shell">
            <header class="header">
                <div class="container header-inner">
                    <a class="brand" href="/" aria-label="Pozool home">
                        <Image
                            src={pozoolLogo}
                            alt=""
                            width={64}
                            height={64}
                            format="webp"
                        />
                        <span>Pozool</span>
                    </a>

                    <nav class="nav" aria-label="Blog navigation">
                        <a href="/blog" aria-current="page">Blog</a>
                        <a href="/">Home</a>
                    </nav>

                    <div class="header-actions">
                        <button
                            class="language-toggle"
                            type="button"
                            aria-label="Switch language"
                            data-language-toggle
                        >
                            ES
                        </button>
                    </div>
                </div>
            </header>

            <main>
                <div class="container">
                    <section class="blog-heading" aria-labelledby="blog-title">
                        <h1 id="blog-title">
                            <span class="i18n-en">
                                A home we call <span class="gradient-text"
                                    >Pozool Stays</span
                                >
                            </span>
                            <span class="i18n-es">
                                Un hogar llamado <span class="gradient-text"
                                    >Pozool Stays</span
                                >
                            </span>
                        </h1>
                        <p class="lead">
                            <span class="i18n-en">
                                Updates from the team building hospitality-first
                                property management software.
                            </span>
                            <span class="i18n-es">
                                Notas del equipo que construye software de
                                gestión de propiedades pensado para
                                hospitalidad.
                            </span>
                        </p>
                    </section>

                    <section
                        class="posts"
                        aria-label="Blog posts"
                        data-post-list
                    >
                        {
                            posts.map((post) => (
                                <a
                                    class="post-card"
                                    href={`/blog/${post.slug}`}
                                    lang={post.frontmatter.lang}
                                    data-post-language={post.frontmatter.lang}
                                    hidden={post.frontmatter.lang !== "en"}
                                >
                                    <p class="post-meta">
                                        <span>
                                            {formatPostDate(
                                                post.frontmatter.date,
                                                post.frontmatter.lang,
                                            )}
                                        </span>
                                        <span class="post-language">
                                            {
                                                languageLabels[
                                                    post.frontmatter.lang
                                                ]
                                            }
                                        </span>
                                    </p>
                                    <h2>{post.frontmatter.title}</h2>
                                    <p class="post-content">
                                        {post.frontmatter.excerpt}
                                    </p>
                                </a>
                            ))
                        }
                        <p class="empty-state" data-empty-state hidden>
                            No posts available for this language yet.
                        </p>
                    </section>
                </div>
            </main>
        </div>
        <script>
            const supportedLanguages = ["en", "es"];
            const languageToggle = document.querySelector(
                "[data-language-toggle]",
            );
            const root = document.documentElement;
            const params = new URLSearchParams(window.location.search);
            const queryLanguage = params.get("lang");
            const browserLanguage = navigator.language
                ?.toLowerCase()
                .startsWith("es")
                ? "es"
                : "en";
            const activeLanguage = supportedLanguages.includes(
                queryLanguage ?? "",
            )
                ? queryLanguage
                : browserLanguage;
            const cards = [
                ...document.querySelectorAll("[data-post-language]"),
            ];
            const emptyState = document.querySelector("[data-empty-state]");
            const languageCopy = {
                en: {
                    nextLabel: "ES",
                    aria: "Switch language to Spanish",
                    title: "Pozool Blog",
                    description:
                        "Updates from the team building hospitality-first property management software.",
                },
                es: {
                    nextLabel: "EN",
                    aria: "Cambiar idioma a inglés",
                    title: "Blog de Pozool",
                    description:
                        "Notas del equipo que construye software de gestión de propiedades pensado para hospitalidad.",
                },
            };

            const setLanguage = (language, shouldUpdateUrl = false) => {
                const activeLanguage = language === "es" ? "es" : "en";
                const copy = languageCopy[activeLanguage];
                let visibleCount = 0;

                root.dataset.lang = activeLanguage;
                root.lang = activeLanguage;
                document.title = copy.title;
                document
                    .querySelector('meta[name="description"]')
                    ?.setAttribute("content", copy.description);
                document
                    .querySelector('meta[property="og:description"]')
                    ?.setAttribute("content", copy.description);

                cards.forEach((card) => {
                    const isVisible =
                        card.getAttribute("data-post-language") ===
                        activeLanguage;
                    card.toggleAttribute("hidden", !isVisible);
                    visibleCount += isVisible ? 1 : 0;
                });

                if (languageToggle) {
                    languageToggle.textContent = copy.nextLabel;
                    languageToggle.setAttribute("aria-label", copy.aria);
                }

                emptyState?.toggleAttribute("hidden", visibleCount > 0);
                window.localStorage.setItem(
                    "pozool-language",
                    activeLanguage,
                );

                if (shouldUpdateUrl) {
                    const nextUrl = new URL(window.location.href);
                    nextUrl.searchParams.set("lang", activeLanguage);
                    window.history.replaceState({}, "", nextUrl);
                }
            };

            setLanguage(activeLanguage);

            languageToggle?.addEventListener("click", () => {
                setLanguage(root.dataset.lang === "es" ? "en" : "es", true);
            });
        </script>
        <Analytics />
    </body>
</html>
