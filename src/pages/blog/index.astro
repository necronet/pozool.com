---
import Analytics from "@vercel/analytics/astro";

const postDate = "April 29, 2026";
const postUrl = "/blog/and-now-we-have-arrived-pozool-stays";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Pozool" />
    <meta
      name="description"
      content="Updates and notes from the Pozool team."
    />
    <meta property="og:title" content="Pozool Blog" />
    <meta
      property="og:description"
      content="Updates and notes from the Pozool team."
    />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <title>Pozool Blog</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --radius: 0.75rem;
        --background: oklch(99% 0.005 70);
        --foreground: oklch(18% 0.02 60);
        --card: oklch(100% 0 0);
        --primary: oklch(70% 0.19 45);
        --primary-glow: oklch(78% 0.17 55);
        --secondary: oklch(96% 0.012 70);
        --muted-foreground: oklch(50% 0.02 60);
        --border: oklch(92% 0.012 70);
        --ink-soft: oklch(32% 0.02 60);
        --surface-warm: oklch(97% 0.02 70);
        --gradient-primary: linear-gradient(135deg, oklch(70% 0.19 45), oklch(78% 0.17 55));
        --gradient-warm: linear-gradient(180deg, oklch(99% 0.01 80), oklch(96% 0.03 60));
        --shadow-elegant: 0 20px 50px -20px oklab(70% 0.13435 0.13435 / 0.3);
        --shadow-soft: 0 10px 30px -15px rgb(0 0 0 / 0.12);
        --transition-smooth: 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Inter", system-ui, sans-serif;
        background: var(--background);
        color: var(--foreground);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .site-shell {
        min-height: 100vh;
        background: var(--gradient-warm);
      }

      .container {
        width: min(100%, 72rem);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgb(252 251 248 / 0.8);
        backdrop-filter: blur(14px);
        border-bottom: 1px solid rgb(230 225 214 / 0.7);
      }

      .header-inner {
        min-height: 4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        font-size: 1.125rem;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      .brand img {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: calc(var(--radius) - 0.125rem);
        box-shadow: var(--shadow-soft);
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }

      .nav a {
        padding: 0.625rem 0.75rem;
        border-radius: calc(var(--radius) - 0.125rem);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--ink-soft);
        transition: color var(--transition-smooth), background var(--transition-smooth);
      }

      .nav a:hover,
      .nav a[aria-current="page"] {
        color: var(--foreground);
        background: rgb(255 255 255 / 0.55);
      }

      main {
        padding: clamp(4rem, 9vw, 7rem) 0;
      }

      .blog-heading {
        max-width: 44rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      .eyebrow-dot {
        width: 0.375rem;
        height: 0.375rem;
        border-radius: 999px;
        background: var(--primary);
      }

      h1,
      h2,
      p {
        margin: 0;
      }

      h1 {
        margin-top: 1.25rem;
        font-size: clamp(3rem, 8vw, 4.5rem);
        line-height: 0.98;
        letter-spacing: -0.04em;
        text-wrap: balance;
      }

      .gradient-text {
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .lead {
        margin-top: 1.25rem;
        max-width: 36rem;
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--ink-soft);
      }

      .posts {
        margin-top: clamp(2.5rem, 6vw, 4rem);
        display: grid;
        gap: 1.5rem;
      }

      .post-card {
        display: block;
        padding: clamp(1.5rem, 4vw, 2.5rem);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: rgb(255 255 255 / 0.78);
        box-shadow: var(--shadow-elegant);
        transition: transform var(--transition-smooth), border-color var(--transition-smooth),
          background var(--transition-smooth);
      }

      .post-card:hover {
        transform: translateY(-2px);
        border-color: rgb(221 130 71 / 0.42);
        background: rgb(255 255 255 / 0.9);
      }

      .post-meta {
        color: var(--primary);
        font-size: 0.875rem;
        font-weight: 700;
      }

      .post-card h2 {
        margin-top: 0.75rem;
        max-width: 46rem;
        font-size: clamp(2rem, 5vw, 3.25rem);
        line-height: 1;
        letter-spacing: -0.035em;
        text-wrap: balance;
      }

      .post-content {
        margin-top: 1.25rem;
        max-width: 40rem;
        color: var(--muted-foreground);
        font-size: 1.125rem;
        line-height: 1.8;
      }

      @media (max-width: 36rem) {
        .container {
          padding: 0 1rem;
        }

        .brand {
          font-size: 1rem;
        }

        .nav a {
          padding: 0.55rem 0.625rem;
        }

        main {
          padding-top: 3rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell">
      <header class="header">
        <div class="container header-inner">
          <a class="brand" href="/" aria-label="Pozool home">
            <img src="/pozool-logo.png" alt="" />
            <span>Pozool</span>
          </a>

          <nav class="nav" aria-label="Blog navigation">
            <a href="/blog" aria-current="page">Blog</a>
            <a href="/">Home</a>
          </nav>
        </div>
      </header>

      <main>
        <div class="container">
          <section class="blog-heading" aria-labelledby="blog-title">
            <h1 id="blog-title">Random thoughs from <span class="gradient-text">Pozool</span></h1>
            <p class="lead">
              Updates from the team building hospitality-first property management software.
            </p>
          </section>

          <section class="posts" aria-label="Blog posts">
            <a class="post-card" href={postUrl}>
              <p class="post-meta">{postDate}</p>
              <h2>And now we have arrived.... Pozool stays.</h2>
              <p class="post-content">Hello from the Pozool team.</p>
            </a>
          </section>
        </div>
      </main>
    </div>
    <Analytics />
  </body>
</html>
