const footerCompany = [{ label: { en: "Team", es: "Equipo" }, href: "#team" }];

const footerProduct = [
    { label: { en: "Pozool Stays", es: "Pozool Stays" }, href: "#product" },
    { label: { en: "Features", es: "Funciones" }, href: "#features" },
    { label: { en: "Contact", es: "Contacto" }, href: "#contact" },
];

const footerLegal = [
