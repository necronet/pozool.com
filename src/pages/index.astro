---

<html lang="en" data-lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="author" content="Pozool" />
        <meta
            name="description"
            content="Run your full rental operation in one place: reservations, calendar, payments, guest communication, and operations. Built hospitality-first."
        />
        <meta
            property="og:title"
            content="Pozool — Hospitality-first property management"
        />
        <meta
            property="og:description"
            content="Reservations, calendar, payments, guest communication, and operations — clear, reliable, built for real operators."
        />
        <meta property="og:type" content="website" />
        <meta
            name="twitter:title"
            content="Pozool — Property management for short & long-term rentals"
        />
        <meta
            name="twitter:description"
            content="Pozool is a hospitality-first PMS that handles the full operational lifecycle of short and long-term rentals — reservations, calendars, payments, guest comms and operations in one place."
        />
        <meta name="twitter:card" content="summary" />
        <title>
            Pozool — Property management for short & long-term rentals
        </title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --radius: 0.75rem;
                --background: oklch(99% 0.005 70);
                --foreground: #000;
                --card: oklch(100% 0 0);
                --primary: oklch(70% 0.19 45);
                --primary-foreground: oklch(100% 0 0);
                --primary-glow: oklch(78% 0.17 55);
                --secondary: oklch(96% 0.012 70);
                --muted: oklch(96% 0.01 70);
                --muted-foreground: #000;
                --border: oklch(92% 0.012 70);
                --ink-soft: #000;
                --surface-warm: oklch(97% 0.02 70);
                --gradient-primary: linear-gradient(
                    135deg,
                    oklch(70% 0.19 45),
                    oklch(78% 0.17 55)
                );
                --gradient-warm: linear-gradient(
                    180deg,
                    oklch(99% 0.01 80),
                    oklch(96% 0.03 60)
                );
                --gradient-ink: linear-gradient(
                    135deg,
                    oklch(20% 0.02 60),
                    oklch(28% 0.03 50)
                );
                --shadow-elegant: 0 20px 50px -20px
                    oklab(70% 0.13435 0.13435 / 0.3);
                --shadow-soft: 0 10px 30px -15px
                    oklab(18% 0.01 0.0173205 / 0.25);
                --shadow-card:
                    0 1px 2px rgb(0 0 0 / 0.04),
                    0 8px 24px -12px rgb(0 0 0 / 0.08);
                --transition-smooth: 0.35s cubic-bezier(0.22, 1, 0.36, 1);
            }

            * {
                box-sizing: border-box;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                margin: 0;
                font-family: "Inter", system-ui, sans-serif;
                background: var(--background);
                color: var(--foreground);
                -webkit-font-smoothing: antialiased;
                text-rendering: optimizeLegibility;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            img {
                display: block;
                max-width: 100%;
            }

            .site-shell {
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            .container {
                width: min(100%, 80rem);
                margin: 0 auto;
                padding: 0 1.5rem;
            }

            .header {
                position: sticky;
                top: 0;
                z-index: 50;
                background: rgb(252 251 248 / 0.8);
                backdrop-filter: blur(14px);
                border-bottom: 1px solid rgb(230 225 214 / 0.7);
            }

            .header-inner {
                min-height: 4rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
            }

            .brand {
                display: inline-flex;
                align-items: center;
                gap: 0.625rem;
                font-size: 1.125rem;
                font-weight: 700;
                letter-spacing: -0.025em;
            }

            .brand img {
                width: 2.25rem;
                height: 2.25rem;
                border-radius: calc(var(--radius) - 0.125rem);
                box-shadow: var(--shadow-soft);
            }

            .nav {
                display: none;
                align-items: center;
                gap: 0.25rem;
            }

            .nav a {
                padding: 0.625rem 0.75rem;
                border-radius: calc(var(--radius) - 0.125rem);
                font-size: 0.875rem;
                font-weight: 500;
                color: var(--ink-soft);
                transition:
                    color var(--transition-smooth),
                    background var(--transition-smooth);
            }

            .nav a:hover,
            .nav a.active {
                color: var(--foreground);
                background: rgb(255 255 255 / 0.55);
            }

            .desktop-cta {
                display: none;
            }

            .header-actions {
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }

            .button,
            .button-secondary {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                min-height: 3rem;
                padding: 0 1.5rem;
                border-radius: 999px;
                font-size: 0.875rem;
                font-weight: 600;
                transition:
                    transform var(--transition-smooth),
                    background var(--transition-smooth),
                    color var(--transition-smooth),
                    border-color var(--transition-smooth);
            }

            .button:hover,
            .button-secondary:hover {
                transform: translateY(-1px);
            }

            .button {
                background: var(--gradient-primary);
                color: var(--primary-foreground);
                box-shadow: var(--shadow-elegant);
            }

            .button-secondary {
                background: var(--card);
                color: var(--foreground);
                border: 1px solid var(--border);
            }

            .language-toggle {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 2.75rem;
                height: 2.5rem;
                padding: 0 0.8rem;
                border: 1px solid var(--border);
                border-radius: 999px;
                background: rgb(255 255 255 / 0.75);
                color: var(--foreground);
                font: inherit;
                font-size: 0.8rem;
                font-weight: 700;
                cursor: pointer;
                transition:
                    transform var(--transition-smooth),
                    background var(--transition-smooth);
            }

            .language-toggle:hover {
                transform: translateY(-1px);
                background: var(--card);
            }

            .i18n-es {
                display: none;
            }

            html[data-lang="es"] .i18n-en {
                display: none;
            }

            html[data-lang="es"] .i18n-es {
                display: inline;
            }

            html[data-lang="es"] p.i18n-es,
            html[data-lang="es"] h1.i18n-es,
            html[data-lang="es"] h2.i18n-es,
            html[data-lang="es"] h3.i18n-es,
            html[data-lang="es"] h4.i18n-es,
            html[data-lang="es"] div.i18n-es {
                display: block;
            }

            .mobile-menu {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 2.5rem;
                height: 2.5rem;
                border: 1px solid var(--border);
                border-radius: calc(var(--radius) - 0.125rem);
            }

            .hero {
                position: relative;
                overflow: hidden;
                background: var(--gradient-warm);
                padding: 4rem 0 0;
            }

            .hero-grid {
                display: grid;
                gap: 3rem;
                align-items: center;
            }

            .eyebrow {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.4rem 0.8rem;
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 999px;
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--ink-soft);
            }

            .eyebrow-dot {
                width: 0.375rem;
                height: 0.375rem;
                border-radius: 999px;
                background: var(--primary);
            }

            h1,
            h2,
            h3,
            h4,
            p {
                margin: 0;
            }

            .hero h1 {
                margin-top: 1.5rem;
                font-size: clamp(3rem, 8vw, 4.5rem);
                line-height: 0.98;
                letter-spacing: -0.04em;
                text-wrap: balance;
            }

            .gradient-text {
                background: var(--gradient-primary);
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
            }

            .lead {
                margin-top: 1.5rem;
                max-width: 40rem;
                font-size: 1.125rem;
                line-height: 1.7;
                color: var(--ink-soft);
                text-wrap: balance;
            }

            .hero-actions {
                margin-top: 2rem;
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
            }

            .trust-row {
                margin-top: 2.5rem;
                display: flex;
                flex-wrap: wrap;
                gap: 1rem 2rem;
                color: var(--muted-foreground);
                font-size: 0.95rem;
            }

            .trust-item {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
            }

            .trust-item svg,
            .button svg,
            .feature-icon svg {
                width: 1rem;
                height: 1rem;
            }

            .trust-item svg {
                color: var(--primary);
            }

            .hero-visual {
                position: relative;
                width: 100%;
            }

            .hero-glow {
                position: absolute;
                inset: -1.5rem;
                border-radius: 2rem;
                background: var(--gradient-primary);
                opacity: 0.2;
                filter: blur(3rem);
            }

            .hero-carousel {
                position: relative;
                width: 100%;
                height: min(70vw, 32rem);
                overflow: hidden;
                border-radius: 1.5rem;
                box-shadow: var(--shadow-elegant);
            }

            .hero-photo {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: center;
            }

            .hero-photo:first-child {
                animation: hero-fade-first 24s ease-in-out infinite;
            }

            .hero-photo:nth-child(2) {
                animation: hero-fade-second 24s ease-in-out infinite;
            }

            .hero-photo:nth-child(3) {
                animation: hero-fade-third 24s ease-in-out infinite;
            }

            .hero-photo:nth-child(4) {
                animation: hero-fade-fourth 24s ease-in-out infinite;
            }

            .hero-photo:nth-child(5) {
                animation: hero-fade-fifth 24s ease-in-out infinite;
            }

            .hero-photo:nth-child(6) {
                animation: hero-fade-sixth 24s ease-in-out infinite;
            }

            @keyframes hero-fade-first {
                0%,
                13% {
                    opacity: 1;
                }

                16.666%,
                97% {
                    opacity: 0;
                }

                100% {
                    opacity: 1;
                }
            }

            @keyframes hero-fade-second {
                0%,
                13% {
                    opacity: 0;
                }

                16.666%,
                29.666% {
                    opacity: 1;
                }

                33.333%,
                100% {
                    opacity: 0;
                }
            }

            @keyframes hero-fade-third {
                0%,
                29.666% {
                    opacity: 0;
                }

                33.333%,
                46.333% {
                    opacity: 1;
                }

                50%,
                100% {
                    opacity: 0;
                }
            }

            @keyframes hero-fade-fourth {
                0%,
                46.333% {
                    opacity: 0;
                }

                50%,
                63% {
                    opacity: 1;
                }

                66.666%,
                100% {
                    opacity: 0;
                }
            }

            @keyframes hero-fade-fifth {
                0%,
                63% {
                    opacity: 0;
                }

                66.666%,
                79.666% {
                    opacity: 1;
                }

                83.333%,
                100% {
                    opacity: 0;
                }
            }

            @keyframes hero-fade-sixth {
                0%,
                79.666% {
                    opacity: 0;
                }

                83.333%,
                97% {
                    opacity: 1;
                }

                100% {
                    opacity: 0;
                }
            }

            @media (prefers-reduced-motion: reduce) {
                .hero-photo {
                    animation: none;
                }

                .hero-photo {
                    opacity: 0;
                }

                .hero-photo:first-child {
                    opacity: 1;
                }

                .hero-photo:nth-child(2) {
                    opacity: 0;
                }
            }

            .hero-card {
                position: absolute;
                left: -1.5rem;
                bottom: -1.5rem;
                display: none;
                width: 13.5rem;
                min-height: 7.25rem;
                padding: 1rem;
                border: 1px solid var(--border);
                border-radius: 1rem;
                background: rgb(255 255 255 / 0.7);
                backdrop-filter: blur(12px);
                box-shadow: var(--shadow-card);
            }

            .hero-highlight {
                position: absolute;
                inset: 1rem;
                opacity: 0;
                animation: hero-highlight-fade 16s ease-in-out infinite;
            }

            .hero-highlight:nth-child(2) {
                animation-delay: 4s;
            }

            .hero-highlight:nth-child(3) {
                animation-delay: 8s;
            }

            .hero-highlight:nth-child(4) {
                animation-delay: 12s;
            }

            .hero-highlight p:first-child {
                font-size: 0.75rem;
                font-weight: 500;
                color: var(--muted-foreground);
            }

            .hero-highlight p:nth-child(2) {
                margin-top: 0.25rem;
                font-size: 1.75rem;
                font-weight: 700;
                letter-spacing: -0.04em;
            }

            .hero-highlight p:last-child {
                font-size: 0.75rem;
                line-height: 1.35;
                color: var(--primary);
            }

            @keyframes hero-highlight-fade {
                0%,
                5% {
                    opacity: 0;
                    transform: translateY(0.4rem);
                }

                10%,
                25% {
                    opacity: 1;
                    transform: translateY(0);
                }

                30%,
                100% {
                    opacity: 0;
                    transform: translateY(-0.4rem);
                }
            }

            @media (prefers-reduced-motion: reduce) {
                .hero-highlight {
                    animation: none;
                    opacity: 0;
                    transform: none;
                }

                .hero-highlight:first-child {
                    opacity: 1;
                }
            }

            .spacer {
                height: 5rem;
            }

            .section {
                padding: 5rem 0;
            }

            .section.tight-top {
                padding-top: 0;
            }

            .section-heading {
                max-width: 48rem;
                margin: 0 auto;
                text-align: center;
            }

            .section-heading h2 {
                margin-top: 1.25rem;
                font-size: clamp(2rem, 4vw, 2.5rem);
                line-height: 1.15;
                letter-spacing: -0.03em;
                text-wrap: balance;
            }

            .section-heading p {
                margin-top: 1.25rem;
                font-size: 1.125rem;
                line-height: 1.7;
                color: var(--ink-soft);
                text-wrap: balance;
            }

            .feature-grid {
                display: grid;
                gap: 1.5rem;
            }

            .feature-card {
                padding: 1.75rem;
                border: 1px solid var(--border);
                border-radius: 1.25rem;
                background: var(--card);
                box-shadow: var(--shadow-card);
                transition:
                    transform var(--transition-smooth),
                    box-shadow var(--transition-smooth);
            }

            .feature-card:hover {
                transform: translateY(-0.25rem);
                box-shadow: var(--shadow-elegant);
            }

            .feature-icon {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 3rem;
                height: 3rem;
                border-radius: 1rem;
                background: var(--gradient-primary);
                color: var(--primary-foreground);
                box-shadow: var(--shadow-elegant);
            }

            .feature-card h3 {
                margin-top: 1.25rem;
                font-size: 1.125rem;
                font-weight: 600;
            }

            .feature-card p {
                margin-top: 0.5rem;
                font-size: 0.95rem;
                line-height: 1.7;
                color: var(--ink-soft);
            }

            .panel {
                padding: 2.5rem;
                border: 1px solid var(--border);
                border-radius: 1.5rem;
                background: var(--surface-warm);
            }

            .team-grid {
                display: grid;
                gap: 1rem;
                margin-top: 2rem;
            }

            .team-card {
                display: grid;
                gap: 0.9rem;
                align-items: start;
                padding: 1.25rem;
                border: 1px solid var(--border);
                border-radius: 1rem;
                background: var(--card);
                box-shadow: var(--shadow-card);
            }

            .team-card-header {
                display: flex;
                align-items: center;
                gap: 0.9rem;
            }

            .team-photo,
            .team-initials {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                flex: 0 0 3rem;
                width: 3rem;
                height: 3rem;
                border-radius: 999px;
            }

            .team-photo {
                display: block;
                object-fit: cover;
                object-position: center;
                border: 2px solid var(--card);
                box-shadow: var(--shadow-soft);
            }

            .team-initials {
                background: var(--gradient-primary);
                color: var(--primary-foreground);
                font-size: 0.9rem;
                font-weight: 800;
                letter-spacing: 0.04em;
            }

            .team-card h3 {
                margin: 0;
                font-size: 1.05rem;
                font-weight: 700;
            }

            .team-role {
                margin-top: 0.25rem;
                color: var(--primary);
                font-size: 0.82rem;
                font-weight: 700;
                text-transform: uppercase;
            }

            .team-bio {
                margin-top: 0;
                color: var(--ink-soft);
                font-size: 0.95rem;
                line-height: 1.7;
            }

            .ink-card {
                padding: 2.5rem;
                border-radius: 1.5rem;
                background: var(--gradient-ink);
                color: var(--primary-foreground);
                box-shadow: var(--shadow-elegant);
            }

            .ink-card p:first-child {
                font-size: 0.8rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: rgb(255 255 255 / 0.62);
            }

            .ink-card p:nth-child(2) {
                margin-top: 1rem;
                font-size: 1.7rem;
                font-weight: 600;
                line-height: 1.45;
            }

            .ink-card p:last-child {
                margin-top: 1.5rem;
                font-size: 0.9rem;
                color: rgb(255 255 255 / 0.62);
            }

            .cta-banner {
                padding: 2.5rem;
                text-align: center;
                border-radius: 1.5rem;
                background: var(--gradient-primary);
                color: var(--primary-foreground);
                box-shadow: var(--shadow-elegant);
            }

            .cta-banner h2 {
                max-width: 42rem;
                margin: 0 auto;
                font-size: clamp(2rem, 4vw, 2.5rem);
                line-height: 1.15;
                letter-spacing: -0.03em;
                text-wrap: balance;
            }

            .cta-banner p {
                max-width: 36rem;
                margin: 1rem auto 0;
                font-size: 1.05rem;
                line-height: 1.7;
                color: rgb(255 255 255 / 0.85);
            }

            .cta-banner .button-secondary {
                display: inline-flex;
                width: auto;
                margin-top: 2rem;
                padding-inline: 1.75rem;
                background: var(--card);
                white-space: nowrap;
            }

            .cta-banner .contact-email {
                margin-top: 1rem;
                font-size: 0.95rem;
            }

            .cta-banner .contact-email a {
                color: var(--primary-foreground);
                font-weight: 600;
                text-decoration: underline;
                text-underline-offset: 0.2em;
            }

            .anchor-copy {
                color: var(--ink-soft);
            }

            .anchor-list {
                margin-top: 0.75rem;
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
            }

            .anchor-pill {
                display: inline-flex;
                min-height: 2.75rem;
                align-items: center;
                padding: 0 1rem;
                border-radius: 999px;
                border: 1px solid var(--border);
                background: var(--card);
                font-size: 0.875rem;
                font-weight: 600;
            }

            .footer {
                margin-top: 6rem;
                border-top: 1px solid var(--border);
                background: var(--surface-warm);
            }

            .footer-main {
                display: grid;
                gap: 3rem;
                padding: 4rem 0;
            }

            .footer-main p {
                margin-top: 1rem;
                max-width: 22rem;
                font-size: 0.95rem;
                line-height: 1.7;
                color: var(--muted-foreground);
            }

            .footer-column h4 {
                font-size: 0.9rem;
                font-weight: 600;
            }

            .footer-column ul {
                margin: 1rem 0 0;
                padding: 0;
                list-style: none;
            }

            .footer-column li + li {
                margin-top: 0.75rem;
            }

            .footer-column a {
                font-size: 0.95rem;
                color: var(--muted-foreground);
            }

            .footer-main p a {
                color: var(--foreground);
                font-weight: 600;
            }

            .footer-bottom {
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
                padding: 1.5rem 0;
                border-top: 1px solid var(--border);
                font-size: 0.75rem;
                color: var(--muted-foreground);
            }

            @media (min-width: 40rem) {
                .hero {
                    padding-top: 6rem;
                }

                .hero-card {
                    display: block;
                }

                .spacer {
                    height: 7rem;
                }

                .panel,
                .cta-banner {
                    padding: 3.5rem;
                }
            }

            @media (min-width: 64rem) {
                .nav,
                .desktop-cta {
                    display: flex;
                }

                .mobile-menu {
                    display: none;
                }

                .hero-grid {
                    grid-template-columns: repeat(12, minmax(0, 1fr));
                    gap: 1.5rem;
                }

                .hero-copy {
                    grid-column: span 5 / span 5;
                }

                .hero-visual {
                    grid-column: span 7 / span 7;
                    max-width: 39rem;
                    margin-left: auto;
                }

                .hero-carousel {
                    height: min(42vw, 33.5rem);
                }

                .feature-grid {
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                }

                .team-grid {
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                }

                .footer-main {
                    grid-template-columns: 2fr 1fr 1fr 1fr;
                }

                .footer-bottom {
                    flex-direction: row;
                    align-items: center;
                    justify-content: space-between;
                }
            }
        </style>
    </head>
    <body>
