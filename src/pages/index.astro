---
const navItems = [
  { label: "Home", href: "#top" },
  { label: "Product", href: "#product" },
  { label: "Features", href: "#features" },
  { label: "About", href: "#about" },
  { label: "Core Values", href: "#values" },
  { label: "Team", href: "#team" },
  { label: "FAQ", href: "#faq" },
];

const features = [
  {
    title: "Unified calendar",
    body: "Every property, every channel, every stay — one synced view.",
    icon: "calendar",
  },
  {
    title: "Payment tracking",
    body: "Know exactly what's paid, pending, or overdue at any moment.",
    icon: "card",
  },
  {
    title: "Guest communication",
    body: "Centralized messaging with templates and timely automations.",
    icon: "message",
  },
  {
    title: "Operations & maintenance",
    body: "Cleanings, turnovers, and tickets — assigned and tracked.",
    icon: "wrench",
  },
  {
    title: "Owner visibility",
    body: "Clean owner statements and performance views, always up to date.",
    icon: "building",
  },
  {
    title: "Reporting that helps",
    body: "Operational clarity, not vanity dashboards.",
    icon: "chart",
  },
];

const stats = [
  { value: "100%", label: "Operator-built workflows" },
  { value: "1 view", label: "All properties, one calendar" },
  { value: "0", label: "Spreadsheets needed" },
];

const footerCompany = [
  { label: "About", href: "#about" },
  { label: "Team", href: "#team" },
  { label: "Core Values", href: "#values" },
  { label: "Why Pozool", href: "#why" },
];

const footerProduct = [
  { label: "Pozool Stays", href: "#product" },
  { label: "Features", href: "#features" },
  { label: "FAQ", href: "#faq" },
  { label: "Contact", href: "#contact" },
];

const footerLegal = [
  { label: "Privacy Policy", href: "#privacy" },
  { label: "Terms of Service", href: "#terms" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Pozool" />
    <meta
      name="description"
      content="Run your full rental operation in one place: reservations, calendar, payments, guest communication, and operations. Built hospitality-first."
    />
    <meta property="og:title" content="Pozool — Hospitality-first property management" />
    <meta
      property="og:description"
      content="Reservations, calendar, payments, guest communication, and operations — clear, reliable, built for real operators."
    />
    <meta property="og:type" content="website" />
    <meta
      name="twitter:title"
      content="Pozool — Property management for short & long-term rentals"
    />
    <meta
      name="twitter:description"
      content="Pozool is a hospitality-first PMS that handles the full operational lifecycle of short and long-term rentals — reservations, calendars, payments, guest comms and operations in one place."
    />
    <meta name="twitter:card" content="summary" />
    <title>Pozool — Property management for short & long-term rentals</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --radius: 0.75rem;
        --background: oklch(99% 0.005 70);
        --foreground: oklch(18% 0.02 60);
        --card: oklch(100% 0 0);
        --primary: oklch(70% 0.19 45);
        --primary-foreground: oklch(100% 0 0);
        --primary-glow: oklch(78% 0.17 55);
        --secondary: oklch(96% 0.012 70);
        --muted: oklch(96% 0.01 70);
        --muted-foreground: oklch(50% 0.02 60);
        --border: oklch(92% 0.012 70);
        --ink-soft: oklch(32% 0.02 60);
        --surface-warm: oklch(97% 0.02 70);
        --gradient-primary: linear-gradient(135deg, oklch(70% 0.19 45), oklch(78% 0.17 55));
        --gradient-warm: linear-gradient(180deg, oklch(99% 0.01 80), oklch(96% 0.03 60));
        --gradient-ink: linear-gradient(135deg, oklch(20% 0.02 60), oklch(28% 0.03 50));
        --shadow-elegant: 0 20px 50px -20px oklab(70% 0.13435 0.13435 / 0.3);
        --shadow-soft: 0 10px 30px -15px oklab(18% 0.01 0.0173205 / 0.25);
        --shadow-card: 0 1px 2px rgb(0 0 0 / 0.04), 0 8px 24px -12px rgb(0 0 0 / 0.08);
        --transition-smooth: 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Inter", system-ui, sans-serif;
        background: var(--background);
        color: var(--foreground);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .container {
        width: min(100%, 80rem);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgb(252 251 248 / 0.8);
        backdrop-filter: blur(14px);
        border-bottom: 1px solid rgb(230 225 214 / 0.7);
      }

      .header-inner {
        min-height: 4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        font-size: 1.125rem;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      .brand img {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: calc(var(--radius) - 0.125rem);
        box-shadow: var(--shadow-soft);
      }

      .nav {
        display: none;
        align-items: center;
        gap: 0.25rem;
      }

      .nav a {
        padding: 0.625rem 0.75rem;
        border-radius: calc(var(--radius) - 0.125rem);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--ink-soft);
        transition: color var(--transition-smooth), background var(--transition-smooth);
      }

      .nav a:hover,
      .nav a.active {
        color: var(--foreground);
        background: rgb(255 255 255 / 0.55);
      }

      .desktop-cta {
        display: none;
      }

      .button,
      .button-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-height: 3rem;
        padding: 0 1.5rem;
        border-radius: 999px;
        font-size: 0.875rem;
        font-weight: 600;
        transition: transform var(--transition-smooth), background var(--transition-smooth),
          color var(--transition-smooth), border-color var(--transition-smooth);
      }

      .button:hover,
      .button-secondary:hover {
        transform: translateY(-1px);
      }

      .button {
        background: var(--gradient-primary);
        color: var(--primary-foreground);
        box-shadow: var(--shadow-elegant);
      }

      .button-secondary {
        background: var(--card);
        color: var(--foreground);
        border: 1px solid var(--border);
      }

      .mobile-menu {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border: 1px solid var(--border);
        border-radius: calc(var(--radius) - 0.125rem);
      }

      .hero {
        position: relative;
        overflow: hidden;
        background: var(--gradient-warm);
        padding: 4rem 0 0;
      }

      .hero-grid {
        display: grid;
        gap: 3rem;
        align-items: center;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      .eyebrow-dot {
        width: 0.375rem;
        height: 0.375rem;
        border-radius: 999px;
        background: var(--primary);
      }

      h1,
      h2,
      h3,
      h4,
      p {
        margin: 0;
      }

      .hero h1 {
        margin-top: 1.5rem;
        font-size: clamp(3rem, 8vw, 4.5rem);
        line-height: 0.98;
        letter-spacing: -0.04em;
        text-wrap: balance;
      }

      .gradient-text {
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .lead {
        margin-top: 1.5rem;
        max-width: 40rem;
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--ink-soft);
        text-wrap: balance;
      }

      .hero-actions {
        margin-top: 2rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .trust-row {
        margin-top: 2.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 2rem;
        color: var(--muted-foreground);
        font-size: 0.95rem;
      }

      .trust-item {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }

      .trust-item svg,
      .button svg,
      .feature-icon svg {
        width: 1rem;
        height: 1rem;
      }

      .trust-item svg {
        color: var(--primary);
      }

      .hero-visual {
        position: relative;
        width: 100%;
      }

      .hero-glow {
        position: absolute;
        inset: -1.5rem;
        border-radius: 2rem;
        background: var(--gradient-primary);
        opacity: 0.2;
        filter: blur(3rem);
      }

      .hero-photo {
        position: relative;
        width: 100%;
        height: min(70vw, 32rem);
        object-fit: cover;
        object-position: center;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-elegant);
      }

      .hero-card {
        position: absolute;
        left: -1.5rem;
        bottom: -1.5rem;
        display: none;
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 1rem;
        background: var(--card);
        box-shadow: var(--shadow-card);
      }

      .hero-card p:first-child {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--muted-foreground);
      }

      .hero-card p:nth-child(2) {
        margin-top: 0.25rem;
        font-size: 1.75rem;
        font-weight: 700;
      }

      .hero-card p:last-child {
        font-size: 0.75rem;
        color: var(--primary);
      }

      .spacer {
        height: 5rem;
      }

      .section {
        padding: 5rem 0;
      }

      .section.tight-top {
        padding-top: 0;
      }

      .section-heading {
        max-width: 48rem;
        margin: 0 auto;
        text-align: center;
      }

      .section-heading h2 {
        margin-top: 1.25rem;
        font-size: clamp(2rem, 4vw, 2.5rem);
        line-height: 1.15;
        letter-spacing: -0.03em;
        text-wrap: balance;
      }

      .section-heading p {
        margin-top: 1.25rem;
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--ink-soft);
        text-wrap: balance;
      }

      .feature-grid {
        display: grid;
        gap: 1.5rem;
      }

      .feature-card {
        padding: 1.75rem;
        border: 1px solid var(--border);
        border-radius: 1.25rem;
        background: var(--card);
        box-shadow: var(--shadow-card);
        transition: transform var(--transition-smooth), box-shadow var(--transition-smooth);
      }

      .feature-card:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-elegant);
      }

      .feature-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 3rem;
        height: 3rem;
        border-radius: 1rem;
        background: var(--gradient-primary);
        color: var(--primary-foreground);
        box-shadow: var(--shadow-elegant);
      }

      .feature-card h3 {
        margin-top: 1.25rem;
        font-size: 1.125rem;
        font-weight: 600;
      }

      .feature-card p {
        margin-top: 0.5rem;
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--ink-soft);
      }

      .section-link {
        margin-top: 3rem;
        text-align: center;
      }

      .section-link a {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--primary);
        font-size: 0.95rem;
        font-weight: 600;
      }

      .panel {
        padding: 2.5rem;
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        background: var(--surface-warm);
      }

      .split-grid {
        display: grid;
        gap: 2.5rem;
        align-items: center;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .stat-card {
        padding: 1.25rem;
        text-align: center;
        border: 1px solid var(--border);
        border-radius: 1rem;
        background: var(--card);
        box-shadow: var(--shadow-card);
      }

      .stat-card strong {
        display: block;
        font-size: 1.9rem;
        font-weight: 700;
        letter-spacing: -0.04em;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .stat-card span {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.75rem;
        color: var(--muted-foreground);
      }

      .ink-card {
        padding: 2.5rem;
        border-radius: 1.5rem;
        background: var(--gradient-ink);
        color: var(--primary-foreground);
        box-shadow: var(--shadow-elegant);
      }

      .ink-card p:first-child {
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgb(255 255 255 / 0.62);
      }

      .ink-card p:nth-child(2) {
        margin-top: 1rem;
        font-size: 1.7rem;
        font-weight: 600;
        line-height: 1.45;
      }

      .ink-card p:last-child {
        margin-top: 1.5rem;
        font-size: 0.9rem;
        color: rgb(255 255 255 / 0.62);
      }

      .cta-banner {
        padding: 2.5rem;
        text-align: center;
        border-radius: 1.5rem;
        background: var(--gradient-primary);
        color: var(--primary-foreground);
        box-shadow: var(--shadow-elegant);
      }

      .cta-banner h2 {
        max-width: 42rem;
        margin: 0 auto;
        font-size: clamp(2rem, 4vw, 2.5rem);
        line-height: 1.15;
        letter-spacing: -0.03em;
        text-wrap: balance;
      }

      .cta-banner p {
        max-width: 36rem;
        margin: 1rem auto 0;
        font-size: 1.05rem;
        line-height: 1.7;
        color: rgb(255 255 255 / 0.85);
      }

      .cta-banner .button-secondary {
        margin-top: 2rem;
        background: var(--card);
      }

      .anchor-copy {
        color: var(--ink-soft);
      }

      .anchor-list {
        margin-top: 0.75rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .anchor-pill {
        display: inline-flex;
        min-height: 2.75rem;
        align-items: center;
        padding: 0 1rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--card);
        font-size: 0.875rem;
        font-weight: 600;
      }

      .footer {
        margin-top: 6rem;
        border-top: 1px solid var(--border);
        background: var(--surface-warm);
      }

      .footer-main {
        display: grid;
        gap: 3rem;
        padding: 4rem 0;
      }

      .footer-main p {
        margin-top: 1rem;
        max-width: 22rem;
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--muted-foreground);
      }

      .footer-column h4 {
        font-size: 0.9rem;
        font-weight: 600;
      }

      .footer-column ul {
        margin: 1rem 0 0;
        padding: 0;
        list-style: none;
      }

      .footer-column li + li {
        margin-top: 0.75rem;
      }

      .footer-column a {
        font-size: 0.95rem;
        color: var(--muted-foreground);
      }

      .footer-bottom {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1.5rem 0;
        border-top: 1px solid var(--border);
        font-size: 0.75rem;
        color: var(--muted-foreground);
      }

      @media (min-width: 40rem) {
        .hero {
          padding-top: 6rem;
        }

        .hero-card {
          display: block;
        }

        .spacer {
          height: 7rem;
        }

        .panel,
        .cta-banner {
          padding: 3.5rem;
        }
      }

      @media (min-width: 64rem) {
        .nav,
        .desktop-cta {
          display: flex;
        }

        .mobile-menu {
          display: none;
        }

        .hero-grid {
          grid-template-columns: repeat(12, minmax(0, 1fr));
          gap: 1.5rem;
        }

        .hero-copy {
          grid-column: span 5 / span 5;
        }

        .hero-visual {
          grid-column: span 7 / span 7;
          max-width: 39rem;
          margin-left: auto;
        }

        .hero-photo {
          height: min(42vw, 33.5rem);
        }

        .feature-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .split-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .footer-main {
          grid-template-columns: 2fr 1fr 1fr 1fr;
        }

        .footer-bottom {
          flex-direction: row;
          align-items: center;
          justify-content: space-between;
        }
      }

      @media (max-width: 47.99rem) {
        .stats {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-shell" id="top">
      <header class="header">
        <div class="container header-inner">
          <a class="brand" href="#top">
            <img src="/pozool-logo.png" alt="Pozool" />
            <span>Pozool</span>
          </a>

          <nav class="nav" aria-label="Primary">
            {navItems.map((item, index) => (
              <a href={item.href} class={index === 0 ? "active" : undefined}>{item.label}</a>
            ))}
          </nav>

          <div class="desktop-cta">
            <a class="button" href="#contact">Request a demo</a>
          </div>

          <div class="mobile-menu" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 5h16"></path>
              <path d="M4 12h16"></path>
              <path d="M4 19h16"></path>
            </svg>
          </div>
        </div>
      </header>

      <main>
        <section class="hero">
          <div class="container hero-grid">
            <div class="hero-copy">
              <div class="eyebrow">
                <span class="eyebrow-dot"></span>
                Hospitality-first PMS
              </div>

              <h1>
                Run your rentals,
                <span class="gradient-text">end to end.</span>
              </h1>

              <p class="lead">
                Pozool is a property management system for short and long-term rentals. We handle
                the entire operational lifecycle so your team can focus on guests, not spreadsheets.
              </p>

              <div class="hero-actions">
                <a class="button" href="#contact">
                  Request a demo
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </a>
                <a class="button-secondary" href="#product">Explore Pozool Stays</a>
              </div>

              <div class="trust-row">
                <span class="trust-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                    <path d="m9 12 2 2 4-4"></path>
                  </svg>
                  Reliable by design
                </span>
                <span class="trust-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 6v6l4 2"></path>
                  </svg>
                  Built for daily ops
                </span>
                <span class="trust-item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path>
                    <path d="M20 2v4"></path>
                    <path d="M22 4h-4"></path>
                    <circle cx="4" cy="20" r="2"></circle>
                  </svg>
                  Hospitality-first
                </span>
              </div>
            </div>

            <div class="hero-visual">
              <div class="hero-glow"></div>
              <img
                class="hero-photo"
                src="/hero-rental.jpg"
                alt="Beautifully styled short-term rental interior at golden hour"
                width="1600"
                height="1100"
              />

              <div class="hero-card">
                <p>Today's check-ins</p>
                <p>12 stays</p>
                <p>All cleanings on track</p>
              </div>
            </div>
          </div>

          <div class="spacer"></div>
        </section>

        <section class="section" id="product">
          <div class="container">
            <div class="section-heading">
              <div class="eyebrow">
                <span class="eyebrow-dot"></span>
                What we do
              </div>
              <h2>One system for the entire operational lifecycle.</h2>
              <p>
                From the moment a reservation lands to the day the guest leaves — and every
                cleaning, payment, message, and report in between — Pozool gives your team
