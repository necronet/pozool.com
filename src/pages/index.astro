        <script>
            const languageToggle = document.querySelector(
                "[data-language-toggle]",
            );
            const root = document.documentElement;
            const languageCopy = {
                en: {
                    nextLabel: "ES",
                    aria: "Switch language to Spanish",
                    title: "Pozool — Property management for short & long-term rentals",
                    description:
                        "Run your full rental operation in one place: reservations, calendar, payments, guest communication, and operations. Built hospitality-first.",
                },
                es: {
                    nextLabel: "EN",
                    aria: "Cambiar idioma a inglés",
                    title: "Pozool — Gestión de propiedades para rentas de corto y largo plazo",
                    description:
                        "Gestiona tu operación de rentas en un solo lugar: reservas, calendario, pagos, comunicación con huéspedes y operaciones. Creado con hospitalidad primero.",
                },
            };

            const setLanguage = (language) => {
                const activeLanguage = language === "es" ? "es" : "en";
                const copy = languageCopy[activeLanguage];

                root.dataset.lang = activeLanguage;
                root.lang = activeLanguage;
                document.title = copy.title;
                document
                    .querySelector('meta[name="description"]')
                    ?.setAttribute("content", copy.description);
                document
                    .querySelector('meta[property="og:description"]')
                    ?.setAttribute("content", copy.description);
                document
                    .querySelector('meta[name="twitter:description"]')
                    ?.setAttribute("content", copy.description);

                if (languageToggle) {
                    languageToggle.textContent = copy.nextLabel;
                    languageToggle.setAttribute("aria-label", copy.aria);
                }

                window.localStorage.setItem("pozool-language", activeLanguage);
            };

            const savedLanguage =
                window.localStorage.getItem("pozool-language");
            setLanguage(savedLanguage || "en");

            languageToggle?.addEventListener("click", () => {
                setLanguage(root.dataset.lang === "es" ? "en" : "es");
            });
        </script>
