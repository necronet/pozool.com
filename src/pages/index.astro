            es: "Las últimas estadías van mejorando",
        },
    },
    {
        label: { en: "Payments received", es: "Pagos recibidos" },
        value: { en: "$8.4k", es: "$8.4k" },
        detail: {
            en: "Owner balances updated",
            es: "Balances de propietarios actualizados",
        },
    },
    {
        label: { en: "Guest check-outs", es: "Check-outs de huéspedes" },
        value: { en: "7 today", es: "7 hoy" },
        detail: {
            en: "Turnovers assigned automatically",
