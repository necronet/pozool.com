{
  "redirects": [
    {
      "source": "/blog",
      "has": [
        {
          "type": "host",
          "value": "blog.pozool.com"
        }
      ],
      "destination": "https://pozool.com/blog",
      "permanent": false
    },
    {
      "source": "/blog/:path*",
      "has": [
        {
          "type": "host",
          "value": "blog.pozool.com"
        }
      ],
      "destination": "https://pozool.com/blog/:path*",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "blog.pozool.com"
        }
      ],
      "destination": "https://pozool.com/blog",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "blog.pozool.com"
        }
      ],
      "destination": "https://pozool.com/blog/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/blog/rss.xml",
      "has": [
        {
          "type": "query",
          "key": "lang",
          "value": "en"
        }
      ],
      "destination": "/blog/rss.en.xml"
    },
    {
      "source": "/blog/rss.xml",
      "has": [
        {
          "type": "query",
          "key": "lang",
          "value": "es"
        }
      ],
      "destination": "/blog/rss.es.xml"
    }
  ]
}
